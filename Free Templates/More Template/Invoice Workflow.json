    {
      "parameters": {
        "jsCode": "// Ambil input dari node sebelumnya\nconst emailText = $input.first().json.output; // sesuaikan dengan field Anda\n\n// Fungsi untuk memisahkan subject dan body\nfunction separateEmailParts(text) {\n  // Cari pattern \"Subject:\" diikuti dengan konten\n  const subjectMatch = text.match(/Subject:\\s*(.+?)(?=\\n\\n|\\nBody:|\\n[A-Z][a-z]+:)/i);\n  \n  // Cari pattern \"Body:\" diikuti dengan konten\n  const bodyMatch = text.match(/Body:\\s*([\\s\\S]+)/i);\n  \n  // Jika tidak ada label \"Subject:\" atau \"Body:\", coba pisahkan berdasarkan paragraf pertama\n  if (!subjectMatch && !bodyMatch) {\n    const lines = text.trim().split('\\n');\n    return {\n      subject: lines[0].trim(),\n      body: lines.slice(1).join('\\n').trim()\n    };\n  }\n  \n  return {\n    subject: subjectMatch ? subjectMatch[1].trim() : '',\n    body: bodyMatch ? bodyMatch[1].trim() : text\n  };\n}\n\n// Pisahkan email\nconst result = separateEmailParts(emailText);\n\n// Return sebagai output\nreturn {\n  subject: result.subject,\n  body: result.body\n};"
      },
