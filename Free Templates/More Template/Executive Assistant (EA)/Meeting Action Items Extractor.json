      "webhookId": "YOUR_WEBHOOK_ID_HERE",
      "credentials": {
        "telegramApi": {
          "id": "YOUR_CREDENTIAL_ID_HERE",
          "name": "Telegram account"
        }
      }
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an executive assistant extracting action items from meeting notes.\n\nMeeting notes:\n{{ $json.message.text }}\n\nTasks:\n1. Identify all action items/tasks\n2. For each task, determine:\n   - Task: what needs to be done\n   - Assignee: who is responsible (if mentioned)\n   - Due Date: deadline (if mentioned, format YYYY-MM-DD)\n3. If assignee not mentioned, use \"Unassigned\"\n4. If due date not mentioned, use \"No deadline\"\n\n{\n  \"meeting_date\": \"time in hours, minutes, and date if mentioned\",\n  \"action_items\": [\n    {\n      \"task\": \"string\",\n      \"assignee\": \"string\",\n      \"due_date\": \"string or null\"\n    }\n  ]\n}\n\nDO NOT USE ```\n\nFOLLOW OUTPUT INSTRUCTION STRICTLY",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        432,
        0
      ],
      "id": "YOUR_NODE_ID_HERE",
      "name": "AI Agent"
    },
    {
      "parameters": {
        "model": "llama-3.3-70b-versatile",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1,
      "position": [
        432,
        176
      ],
      "id": "YOUR_NODE_ID_HERE",
      "name": "Groq Chat Model",
      "credentials": {
        "groqApi": {
          "id": "YOUR_CREDENTIAL_ID_HERE",
          "name": "Groq account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Get raw output from AI\nconst rawOutput = $input.first().json.output || \"\";\n\ntry {\n  // Extract content between { and }\n  const jsonMatch = rawOutput.match(/\\{[\\s\\S]*\\}/);\n  \n  if (!jsonMatch) {\n    throw new Error(\"No JSON format found in output.\");\n  }\n\n  // Clean and parse\n  const cleanJsonString = jsonMatch[0].replace(/\\\\n/g, ' ');\n  const parsedData = JSON.parse(cleanJsonString);\n\n  // Transform into separate items\n  return parsedData.action_items.map(item => {\n    return {\n      json: {\n        task: item.task,\n        assignee: item.assignee,\n        due_date: item.due_date,\n        meeting_date: parsedData.meeting_date || \"N/A\"\n      }\n    };\n  });\n\n} catch (error) {\n  return {\n    json: {\n      error: \"Parse failed: \" + error.message,\n      raw_text: rawOutput\n    }\n  };\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        784,
        0
      ],
      "id": "YOUR_NODE_ID_HERE",
