{
  "name": "Meeting Action Items Extractor",
  "nodes": [
    {
      "parameters": {
        "updates": [
          "message"
        ],
        "additionalFields": {}
      },
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.2,
      "position": [
        192,
        0
      ],
      "id": "YOUR_NODE_ID_HERE",
