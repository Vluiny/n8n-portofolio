    {
      "parameters": {
        "jsCode": "// Get raw data from AI output\nlet rawData = $input.first().json.output;\n\ntry {\n  // If input is still a string (with \\n), parse into object\n  if (typeof rawData === 'string') {\n    // Clean up newline literal characters (\\n) that often cause errors\n    const cleanString = rawData.replace(/\\\\n/g, '').trim();\n    rawData = JSON.parse(cleanString);\n  }\n\n  // Return as clean n8n object\n  return {\n    meeting_type: rawData.meeting_type,\n    meeting_topic: rawData.meeting_topic,\n    meeting_date: rawData.meeting_date,\n    summary: rawData.summary,\n    key_points: rawData.key_points || [],\n    decisions: rawData.decisions || [],\n    action_items: rawData.action_items || [],\n    next_steps: rawData.next_steps\n  };\n\n} catch (error) {\n  // If parsing fails, return raw text to preserve data\n  return {\n    error: \"Failed to parse JSON\",\n    raw_data: rawData\n  };\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
