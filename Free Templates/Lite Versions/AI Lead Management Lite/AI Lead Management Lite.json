    {
      "parameters": {
        "promptType": "define",
        "text": "=Classify the following customer message into one of these categories:\n\nsales\nsupport\nbilling\nother\n\nOnly return one word.\n\nCustomer message:\n{{ $json.message }}",
        "options": {
          "systemMessage": "=You are a lead classification assistant. Your only task is to analyze the incoming customer message and categorize it into exactly one of these categories:\n\n- sales\n- support\n- billing\n- other\n\nRules:\n1. Only output the category name in lowercase.\n2. Do not include punctuation, greetings, or any other text.\n3. If the message is about a product demo, pricing, or interest in services, classify as 'sales'.\n4. If the message is a technical issue, classify as 'support'.\n5. If the message is about payments or invoices, classify as 'billing'.\n6. If it doesn't fit the above, use 'other'."
        }
